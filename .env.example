# SocialMind Environment Variables
# Copy this file to .env and fill in the values

# 4everland AI API key (used server-side only)
FOUREVERLAND_API_KEY=your_4everland_api_key

# Auth secret for JWT signing (generate with: openssl rand -hex 32)
AUTH_SECRET=your_random_secret_here

# Composio — social media OAuth + posting (https://app.composio.dev/settings)
COMPOSIO_API_KEY=your_composio_api_key

# Neon Postgres (https://console.neon.tech -> Connection Details -> Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Firebase (https://console.firebase.google.com -> Project Settings -> General -> Web app)
# Backend uses this to verify tokens
FIREBASE_PROJECT_ID=your-firebase-project-id

# Frontend Firebase config (Vite exposes VITE_* to the browser)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
