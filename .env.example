# SocialMind Environment Variables
# Copy this file to .env and fill in the values

# 4everland AI API key (used server-side only)
FOUREVERLAND_API_KEY=your_4everland_api_key

# Auth secret for JWT signing (generate with: openssl rand -hex 32)
AUTH_SECRET=your_random_secret_here

# Composio — social media OAuth + posting (https://app.composio.dev/settings)
COMPOSIO_API_KEY=your_composio_api_key

# Neon Postgres (https://console.neon.tech -> Connection Details -> Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# App URL
NEXT_PUBLIC_APP_URL=https://openclaw4ever.vercel.app
